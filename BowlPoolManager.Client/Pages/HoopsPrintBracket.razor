@page "/hoops/print-bracket"
@page "/hoops/print-bracket/{EntryId}"
@layout BowlPoolManager.Client.Layout.PrintLayout
@using BowlPoolManager.Core.Domain
@using BowlPoolManager.Core
@using BowlPoolManager.Client.Helpers
@using BowlPoolManager.Client.Services

@inject ISeasonService SeasonService
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime

<PageTitle>Printable Bracket – Hoops Madness</PageTitle>

@if (games == null)
{
    <div class="p-5 text-center">Loading Bracket...</div>
}
else
{
    <div class="text-center mb-2 no-print d-flex gap-2 justify-content-center align-items-center flex-wrap">
        @if (string.IsNullOrEmpty(EntryId) && pools.Count > 1)
        {
            <select class="form-select form-select-sm w-auto" @onchange="OnPoolChanged">
                @foreach (var pool in pools)
                {
                    <option value="@pool.Id" selected="@(pool.Id == currentPool?.Id)">@pool.Name</option>
                }
            </select>
        }
        <button class="btn btn-primary btn-sm" onclick="window.print()">
            <i class="bi bi-printer"></i> Print (Landscape)
        </button>
        <a href="/hoops/mypicks" class="btn btn-outline-secondary btn-sm">Back to My Picks</a>
    </div>

    <div class="print-wrapper">

        @* ── HEADER ── *@
        <div class="header-row">
            <div class="inputs-area">
                <div class="input-field-group">
                    <span class="lbl">Name:</span>
                    <div class="fill-line" style="width: 220px;">
                        @if (userEntry != null) { <span class="handwritten">@userEntry.PlayerName</span> }
                    </div>
                </div>
                <div class="input-field-group">
                    <span class="lbl">Pool:</span>
                    <div class="fill-line" style="width: 180px;">
                        @if (currentPool != null) { <span class="handwritten">@currentPool.Name</span> }
                    </div>
                </div>
            </div>
            <div class="title-area">
                <h1 class="m-0">HOOPS MADNESS @DateTime.Now.Year</h1>
                <div class="url-text">Hoops-Madness.com</div>
            </div>
        </div>

        @* ── FIRST FOUR ── *@
        @if (firstFourGames.Any())
        {
            <div class="section-label">FIRST FOUR — Play-In Games</div>
            <div class="first-four-row">
                @foreach (var game in firstFourGames)
                {
                    <div class="ff-card">
                        <div class="ff-card-header">@game.Region · Seed @game.SeedMatchup</div>
                        <div class="team-slot @GetPickClass(game, game.TeamHome)">
                            <span class="seed-badge">@game.TeamHomeSeed</span>
                            <span class="tname">@Ellipsis(game.TeamHome)</span>
                        </div>
                        <div class="team-slot @GetPickClass(game, game.TeamAway)">
                            <span class="seed-badge">@game.TeamAwaySeed</span>
                            <span class="tname">@Ellipsis(game.TeamAway)</span>
                        </div>
                    </div>
                }
            </div>
        }

        @* ── REGIONAL BRACKETS (2×2 grid) ── *@
        <div class="section-label">REGIONAL BRACKETS</div>
        <div class="regions-grid">
            @foreach (var region in regions)
            {
                var r64 = GetRoundOrdered(region, TournamentRound.RoundOf64);
                var r32 = OrderByFeeder(GetRoundGames(region, TournamentRound.RoundOf32), r64);
                var s16 = OrderByFeeder(GetRoundGames(region, TournamentRound.Sweet16), r32);
                var e8  = OrderByFeeder(GetRoundGames(region, TournamentRound.Elite8), s16);

                <div class="region-section">
                    <div class="region-name">@region.ToUpper()</div>
                    <div class="region-bracket">

                        @* R64 *@
                        <div class="round-col">
                            <div class="round-hdr">R64</div>
                            <div class="games-col">
                                @foreach (var game in r64)
                                {
                                    <div class="match-card">
                                        <div class="team-slot @GetPickClass(game, game.TeamHome)">
                                            <span class="seed-badge">@game.TeamHomeSeed</span>
                                            <span class="tname">@Ellipsis(game.TeamHome)</span>
                                        </div>
                                        <div class="team-slot bottom-team @GetPickClass(game, game.TeamAway)">
                                            <span class="seed-badge">@game.TeamAwaySeed</span>
                                            <span class="tname">@Ellipsis(game.TeamAway)</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        @* R32 *@
                        <div class="round-col">
                            <div class="round-hdr">R32</div>
                            <div class="games-col">
                                @foreach (var game in r32)
                                {
                                    var (h, a) = ResolveTeams(game);
                                    <div class="match-card">
                                        <div class="team-slot @GetPickClass(game, h)">
                                            <span class="seed-badge">@GetSeed(h)</span>
                                            <span class="tname">@Ellipsis(h)</span>
                                        </div>
                                        <div class="team-slot bottom-team @GetPickClass(game, a)">
                                            <span class="seed-badge">@GetSeed(a)</span>
                                            <span class="tname">@Ellipsis(a)</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        @* S16 *@
                        <div class="round-col">
                            <div class="round-hdr">S16</div>
                            <div class="games-col">
                                @foreach (var game in s16)
                                {
                                    var (h, a) = ResolveTeams(game);
                                    <div class="match-card">
                                        <div class="team-slot @GetPickClass(game, h)">
                                            <span class="seed-badge">@GetSeed(h)</span>
                                            <span class="tname">@Ellipsis(h)</span>
                                        </div>
                                        <div class="team-slot bottom-team @GetPickClass(game, a)">
                                            <span class="seed-badge">@GetSeed(a)</span>
                                            <span class="tname">@Ellipsis(a)</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        @* E8 *@
                        <div class="round-col last-col">
                            <div class="round-hdr">E8</div>
                            <div class="games-col">
                                @foreach (var game in e8)
                                {
                                    var (h, a) = ResolveTeams(game);
                                    <div class="match-card no-right-line">
                                        <div class="team-slot @GetPickClass(game, h)">
                                            <span class="seed-badge">@GetSeed(h)</span>
                                            <span class="tname">@Ellipsis(h)</span>
                                        </div>
                                        <div class="team-slot bottom-team @GetPickClass(game, a)">
                                            <span class="seed-badge">@GetSeed(a)</span>
                                            <span class="tname">@Ellipsis(a)</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>

        @* ── FINAL FOUR + CHAMPIONSHIP ── *@
        <div class="section-label">FINAL FOUR &amp; NATIONAL CHAMPIONSHIP</div>
        <div class="ff-bracket-row">
            @foreach (var game in finalFourGames)
            {
                var (h, a) = ResolveTeams(game);
                <div class="ff-game-card">
                    <div class="ff-game-label">National Semifinal</div>
                    <div class="team-slot @GetPickClass(game, h)">
                        <span class="seed-badge">@GetSeed(h)</span>
                        <span class="tname">@Ellipsis(h, 22)</span>
                    </div>
                    <div class="team-slot bottom-team @GetPickClass(game, a)">
                        <span class="seed-badge">@GetSeed(a)</span>
                        <span class="tname">@Ellipsis(a, 22)</span>
                    </div>
                </div>
            }
            @foreach (var game in champGames)
            {
                var (h, a) = ResolveTeams(game);
                <div class="ff-game-card champ-card">
                    <div class="ff-game-label fw-bold">NATIONAL CHAMPIONSHIP</div>
                    <div class="team-slot @GetPickClass(game, h)">
                        <span class="seed-badge">@GetSeed(h)</span>
                        <span class="tname">@Ellipsis(h, 22)</span>
                    </div>
                    <div class="team-slot bottom-team @GetPickClass(game, a)">
                        <span class="seed-badge">@GetSeed(a)</span>
                        <span class="tname">@Ellipsis(a, 22)</span>
                    </div>
                    <div class="champ-winner-line">
                        <span class="fw-bold small me-1">CHAMPION:</span>
                        @if (userEntry?.Picks != null && userEntry.Picks.TryGetValue(game.Id, out var champ))
                        {
                            <span class="handwritten">@champ</span>
                        }
                        else
                        {
                            <span class="line-blank">_____________________</span>
                        }
                    </div>
                </div>
            }
        </div>

        @* ── FOOTER ── *@
        <div class="print-footer">
            <strong>Scoring:</strong>
            First Four: @GetPts(TournamentRound.FirstFour) |
            Round of 64: @GetPts(TournamentRound.RoundOf64) |
            Round of 32: @GetPts(TournamentRound.RoundOf32) |
            Sweet 16: @GetPts(TournamentRound.Sweet16) |
            Elite 8: @GetPts(TournamentRound.Elite8) |
            Final Four: @GetPts(TournamentRound.FinalFour) |
            Championship: @GetPts(TournamentRound.NationalChampionship) pts
        </div>

    </div>
}

<style>
    :root { --border: #888; }

    @@media print {
        @@page { size: landscape; margin: 0.2in; }
        body { zoom: 90%; background-color: white !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .no-print { display: none !important; }
        .match-card { background-color: transparent !important; }
        .user-pick-correct  { box-shadow: inset 0 0 0 1px #198754 !important; background-color: #d1e7dd !important; font-weight: bold; }
        .user-pick-incorrect { box-shadow: inset 0 0 0 1px #dc3545 !important; background-color: #f8d7da !important; font-weight: bold; }
        .user-pick-pending  { box-shadow: inset 0 0 0 1px #0d6efd !important; background-color: #cfe2ff !important; font-weight: bold; }
        .handwritten { color: #dc3545 !important; }
    }

    .print-wrapper { font-family: 'Arial Narrow', Arial, sans-serif; color: #000; max-width: 100%; }

    /* Pick highlight classes */
    .user-pick-correct  { box-shadow: inset 0 0 0 1px #198754; background-color: #d1e7dd; font-weight: bold; }
    .user-pick-incorrect { box-shadow: inset 0 0 0 1px #dc3545; background-color: #f8d7da; font-weight: bold; }
    .user-pick-pending  { box-shadow: inset 0 0 0 1px #0d6efd; background-color: #cfe2ff; font-weight: bold; }
    .handwritten { color: #dc3545; font-weight: 800; font-family: 'Courier New', Courier, monospace; }

    /* ── Header ── */
    .header-row { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 2px solid #000; padding-bottom: 4px; margin-bottom: 5px; }
    .inputs-area { display: flex; gap: 16px; }
    .input-field-group { display: flex; align-items: flex-end; gap: 4px; }
    .lbl { font-weight: bold; font-size: 0.8rem; white-space: nowrap; }
    .fill-line { border-bottom: 1px solid #000; height: 16px; line-height: 16px; padding-left: 4px; font-size: 0.75rem; }
    .title-area { text-align: right; }
    .title-area h1 { font-size: 1.3rem; font-weight: 900; line-height: 1; }
    .url-text { font-size: 0.8rem; font-weight: bold; text-transform: uppercase; color: #444; }

    /* ── Section labels ── */
    .section-label { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: #555; border-top: 1px solid #ccc; padding-top: 3px; margin-top: 5px; margin-bottom: 3px; }

    /* ── First Four ── */
    .first-four-row { display: flex; gap: 6px; margin-bottom: 4px; }
    .ff-card { flex: 1; border: 1px solid var(--border); padding: 2px 4px; font-size: 0.68rem; background: #fafafa; }
    .ff-card-header { font-weight: bold; font-size: 0.6rem; border-bottom: 1px solid #ddd; margin-bottom: 2px; color: #333; }

    /* ── Regions grid ── */
    .regions-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-bottom: 4px; }
    .region-section { border: 1px solid #bbb; padding: 2px 3px; }
    .region-name { font-size: 0.62rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.08em; background: #e9e9e9; padding: 1px 4px; margin: -2px -3px 2px -3px; }
    .region-bracket { display: flex; height: 260px; }

    /* ── Round columns ── */
    .round-col { display: flex; flex-direction: column; flex: 1; position: relative; }
    .round-hdr { text-align: center; font-size: 0.58rem; font-weight: bold; text-transform: uppercase; background: #f0f0f0; border: 1px solid #ccc; height: 14px; line-height: 13px; margin-bottom: 2px; }
    .games-col { display: flex; flex-direction: column; justify-content: space-around; flex: 1; }

    /* ── Match cards ── */
    .match-card { border: 1px solid #aaa; background: #fff; position: relative; margin: 0 2px; }
    .match-card:not(.no-right-line)::after { content: ''; position: absolute; right: -4px; top: 50%; width: 4px; height: 1px; background: #000; }
    .team-slot { display: flex; align-items: center; height: 14px; padding: 0 2px; font-size: 0.6rem; overflow: hidden; white-space: nowrap; }
    .team-slot.bottom-team { border-top: 1px solid #ddd; }
    .seed-badge { font-weight: bold; color: #555; min-width: 14px; text-align: right; margin-right: 2px; font-size: 0.58rem; flex-shrink: 0; }
    .tname { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    /* ── Final Four bracket row ── */
    .ff-bracket-row { display: flex; gap: 8px; align-items: center; margin-bottom: 4px; }
    .ff-game-card { flex: 1; border: 1px solid var(--border); padding: 3px 5px; font-size: 0.68rem; background: #fafafa; }
    .ff-game-card.champ-card { flex: 1.2; border: 2px solid #000; background: #fffbe6; }
    .ff-game-label { font-weight: bold; font-size: 0.6rem; border-bottom: 1px solid #ddd; margin-bottom: 2px; color: #333; }
    .champ-winner-line { border-top: 1px dotted #aaa; margin-top: 4px; padding-top: 3px; font-size: 0.68rem; text-align: center; }
    .line-blank { color: #999; }

    /* ── Footer ── */
    .print-footer { border-top: 1px double #000; padding-top: 3px; font-size: 0.65rem; margin-top: 4px; }
</style>

@code {
    [Parameter] public string? EntryId { get; set; }

    [SupplyParameterFromQuery(Name = "poolId")]
    public string? QueryPoolId { get; set; }

    private List<HoopsGame>? games;
    private List<HoopsPool> pools = new();
    private HoopsPool? currentPool;
    private BracketEntry? userEntry;

    private List<HoopsGame> firstFourGames = new();
    private List<HoopsGame> finalFourGames = new();
    private List<HoopsGame> champGames = new();
    private List<string> regions = new();

    // Seed cache: team name → seed
    private Dictionary<string, int> seedCache = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var season = await SeasonService.GetCurrentSeasonAsync();
            var seasonId = season?.Id ?? "";

            var poolsTask = Http.GetFromJsonAsync<List<HoopsPool>>($"api/GetHoopsPools?seasonId={seasonId}");
            var entryTask = FetchEntry(seasonId);

            await Task.WhenAll(poolsTask, entryTask);

            pools = (await poolsTask ?? new()).Where(p => !p.IsConcluded).ToList();
            userEntry = await entryTask;

            // Determine pool
            if (!string.IsNullOrEmpty(EntryId) && userEntry != null)
            {
                currentPool = pools.FirstOrDefault(p => p.Id == userEntry.PoolId)
                           ?? (await Http.GetFromJsonAsync<List<HoopsPool>>($"api/GetHoopsPools?seasonId={seasonId}"))
                              ?.FirstOrDefault(p => p.Id == userEntry.PoolId);
            }
            else if (!string.IsNullOrEmpty(QueryPoolId))
            {
                currentPool = pools.FirstOrDefault(p => p.Id == QueryPoolId);
            }
            else
            {
                try
                {
                    var saved = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "lastSelectedHoopsPoolId");
                    if (!string.IsNullOrEmpty(saved))
                        currentPool = pools.FirstOrDefault(p => p.Id == saved);
                }
                catch { }
            }

            if (currentPool == null) currentPool = pools.FirstOrDefault();

            await LoadGames();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"HoopsPrintBracket init error: {ex.Message}");
        }
    }

    private async Task<BracketEntry?> FetchEntry(string seasonId)
    {
        if (string.IsNullOrEmpty(EntryId)) return null;
        try { return await Http.GetFromJsonAsync<BracketEntry>($"api/GetHoopsEntry?id={EntryId}&seasonId={seasonId}"); }
        catch { return null; }
    }

    private async Task OnPoolChanged(ChangeEventArgs e)
    {
        var poolId = e.Value?.ToString();
        if (string.IsNullOrEmpty(poolId)) return;
        currentPool = pools.FirstOrDefault(p => p.Id == poolId);
        if (currentPool != null)
        {
            try { await JSRuntime.InvokeVoidAsync("localStorage.setItem", "lastSelectedHoopsPoolId", currentPool.Id); } catch { }
            await LoadGames();
        }
    }

    private async Task LoadGames()
    {
        if (currentPool == null) return;

        try
        {
            games = await Http.GetFromJsonAsync<List<HoopsGame>>($"api/GetHoopsGames?poolId={currentPool.Id}") ?? new();
        }
        catch
        {
            games = new();
        }

        // Build seed cache from R64 and First Four games
        seedCache = new(StringComparer.OrdinalIgnoreCase);
        foreach (var g in games)
        {
            if (!string.IsNullOrEmpty(g.TeamHome) && g.TeamHomeSeed.HasValue)
                seedCache.TryAdd(g.TeamHome, g.TeamHomeSeed.Value);
            if (!string.IsNullOrEmpty(g.TeamAway) && g.TeamAwaySeed.HasValue)
                seedCache.TryAdd(g.TeamAway, g.TeamAwaySeed.Value);
        }

        firstFourGames = games
            .Where(g => g.Round == TournamentRound.FirstFour)
            .OrderBy(g => g.Region)
            .ThenBy(g => g.SeedMatchup)
            .ToList();

        regions = games
            .Where(g => g.Round >= TournamentRound.RoundOf64 && g.Round <= TournamentRound.Elite8 && !string.IsNullOrEmpty(g.Region))
            .Select(g => g.Region!)
            .Distinct()
            .OrderBy(r => r)
            .ToList();

        finalFourGames = games
            .Where(g => g.Round == TournamentRound.FinalFour)
            .OrderBy(g => g.Id)
            .ToList();

        champGames = games
            .Where(g => g.Round == TournamentRound.NationalChampionship)
            .ToList();

        StateHasChanged();
    }

    // ── Game retrieval helpers ──

    private List<HoopsGame> GetRoundGames(string region, TournamentRound round) =>
        games!.Where(g => g.Region == region && g.Round == round).ToList();

    private List<HoopsGame> GetRoundOrdered(string region, TournamentRound round) =>
        GetRoundGames(region, round)
            .OrderBy(g => BracketLayoutHelper.GetSeedMatchupOrder(g.SeedMatchup))
            .ToList();

    private List<HoopsGame> OrderByFeeder(List<HoopsGame> current, List<HoopsGame> previous) =>
        BracketLayoutHelper.OrderByFeeder(current, previous);

    // ── Team resolution ──

    private (string Home, string Away) ResolveTeams(HoopsGame game)
    {
        string home = game.TeamHome ?? "";
        string away = game.TeamAway ?? "";

        var feeders = games!.Where(g => g.NextGameId == game.Id).OrderBy(g => g.Id).ToList();
        int fi = 0;

        if (string.IsNullOrWhiteSpace(home) || home == "TBD")
        {
            if (fi < feeders.Count)
            {
                var f = feeders[fi++];
                if (userEntry?.Picks != null && userEntry.Picks.TryGetValue(f.Id, out var pick) && !string.IsNullOrEmpty(pick))
                    home = pick;
                else
                    home = FeederLabel(f);
            }
        }

        if (string.IsNullOrWhiteSpace(away) || away == "TBD")
        {
            if (fi < feeders.Count)
            {
                var f = feeders[fi];
                if (userEntry?.Picks != null && userEntry.Picks.TryGetValue(f.Id, out var pick) && !string.IsNullOrEmpty(pick))
                    away = pick;
                else
                    away = FeederLabel(f);
            }
        }

        return (home, away);
    }

    private string FeederLabel(HoopsGame feeder)
    {
        if (!string.IsNullOrEmpty(feeder.SeedMatchup)) return $"Win of {feeder.SeedMatchup}";
        if (!string.IsNullOrEmpty(feeder.Region)) return $"{feeder.Region} winner";

        // Final Four feeder → championship: build "Region/Region winner"
        var e8Feeders = games!.Where(g => g.NextGameId == feeder.Id)
            .Select(g => g.Region ?? "").Where(r => r.Length > 0).OrderBy(r => r).ToList();
        return e8Feeders.Any() ? $"{string.Join("/", e8Feeders)} winner" : "TBD";
    }

    // ── Pick class ──

    private string GetPickClass(HoopsGame game, string? teamName)
    {
        if (userEntry?.Picks == null || string.IsNullOrEmpty(teamName)) return "";
        if (!userEntry.Picks.TryGetValue(game.Id, out var pick) || pick != teamName) return "";
        if (game.IsFinal)
            return string.Equals(pick, game.WinningTeamName, StringComparison.OrdinalIgnoreCase)
                ? "user-pick-correct" : "user-pick-incorrect";
        return "user-pick-pending";
    }

    // ── Seed lookup ──

    private string GetSeed(string? teamName)
    {
        if (string.IsNullOrEmpty(teamName)) return "";
        return seedCache.TryGetValue(teamName, out var s) ? s.ToString() : "";
    }

    // ── Point value lookup ──

    private string GetPts(TournamentRound round)
    {
        if (games == null) return "?";
        var sample = games.FirstOrDefault(g => g.Round == round);
        return sample?.PointValue > 0 ? sample.PointValue.ToString() : "—";
    }

    // ── Text truncation ──

    private string Ellipsis(string? text, int max = 16)
    {
        if (string.IsNullOrEmpty(text)) return "";
        return text.Length <= max ? text : text[..max] + "…";
    }
}
