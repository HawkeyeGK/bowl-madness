@page "/admin/hoops-pools"
@using BowlPoolManager.Core.Domain
@using BowlPoolManager.Core
@using BowlPoolManager.Core.Helpers
@using BowlPoolManager.Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = Constants.Roles.SuperAdmin)]
@inject IHoopsPoolService PoolService
@inject ISeasonService SeasonService
@inject IJSRuntime JS

<PageTitle>Basketball Pool Settings</PageTitle>

<div class="container-fluid mt-3 px-4">
    <div class="d-flex justify-content-between align-items-end mb-3">
        <h1 class="h3 fw-bold mb-0"><i class="bi bi-dribbble text-primary"></i> Basketball Pool Settings</h1>
        <button class="btn btn-primary" @onclick="() => EditPool(new HoopsPool())">
            <i class="bi bi-plus-lg"></i> New Pool
        </button>
    </div>

    @if (_isLoading)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Season</th>
                                <th>Status</th>
                                <th>Invite Code</th>
                                <th>Lock Date (Central)</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!_pools.Any())
                            {
                                <tr><td colspan="6" class="text-center text-muted py-4">No basketball pools yet. Create one to get started.</td></tr>
                            }
                            @foreach (var pool in _pools.OrderByDescending(p => p.Season))
                            {
                                <tr>
                                    <td class="fw-bold">@pool.Name</td>
                                    <td>@(_seasons.FirstOrDefault(s => s.Id == pool.SeasonId)?.Name ?? pool.Season.ToString())</td>
                                    <td>
                                        @if (pool.IsArchived)
                                        {
                                            <span class="badge bg-secondary">ARCHIVED</span>
                                        }
                                        else if (pool.IsConcluded)
                                        {
                                            <span class="badge bg-warning text-dark">CONCLUDED</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">ACTIVE</span>
                                        }
                                    </td>
                                    <td><code class="text-primary">@pool.InviteCode</code></td>
                                    <td>
                                        @DateTimeHelper.ToCentral(pool.LockDate).ToString("g")
                                        @if (DateTime.UtcNow > pool.LockDate && !pool.IsConcluded)
                                        {
                                            <span class="badge bg-danger ms-2">LOCKED</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        @if (!pool.IsArchived)
                                        {
                                            <button class="btn btn-sm @(pool.IsConcluded ? "btn-outline-success" : "btn-outline-warning") me-1"
                                                    @onclick="() => ToggleConclusion(pool)"
                                                    title="@(pool.IsConcluded ? "Reopen Pool" : "Conclude Pool")">
                                                <i class="bi @(pool.IsConcluded ? "bi-unlock" : "bi-lock")"></i>
                                            </button>
                                        }
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditPool(pool)">
                                            <i class="bi bi-pencil"></i> Edit
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeletePool(pool)" title="Delete Pool">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@* MODAL FOR POOL EDITING *@
@if (_showModal && _editingPool != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(string.IsNullOrEmpty(_editingPool.Id) ? "Create" : "Edit") Basketball Pool</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <EditForm Model="_editingPool" OnValidSubmit="SavePool">
                    <div class="modal-body">

                        <div class="mb-3">
                            <label class="form-label">Pool Name</label>
                            <InputText @bind-Value="_editingPool.Name" class="form-control" placeholder="e.g. Office Bracket" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Season</label>
                            <InputSelect Value="@_editingPool.SeasonId"
                                         ValueChanged="@((string s) => OnSeasonChanged(s))"
                                         ValueExpression="@(() => _editingPool.SeasonId)"
                                         class="form-select">
                                @foreach (var s in _seasons)
                                {
                                    <option value="@s.Id">@s.Name</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Invite Code</label>
                            <InputText @bind-Value="_editingPool.InviteCode" class="form-control" placeholder="Secret password" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Lock Date (Central Time)</label>
                            <InputText type="datetime-local" class="form-control" @bind-Value="_lockDateString" />
                            <div class="form-text">Picks cannot be changed after this time.</div>
                        </div>

                        <!-- Points Per Round -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Points Per Round</label>
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Round</th>
                                            <th style="width: 120px;">Points</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var round in _basketballRounds)
                                        {
                                            <tr>
                                                <td>@RoundDisplayName(round)</td>
                                                <td>
                                                    <input type="number" min="0" class="form-control form-control-sm"
                                                           value="@GetPointsForRound(round)"
                                                           @onchange="e => SetPointsForRound(round, e.Value?.ToString())" />
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Pool</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<HoopsPool> _pools = new();
    private List<Season> _seasons = new();
    private HoopsPool? _editingPool;
    private bool _isLoading = true;
    private bool _showModal = false;
    private string _lockDateString = "";

    private static readonly TournamentRound[] _basketballRounds =
    {
        TournamentRound.FirstFour,
        TournamentRound.RoundOf64,
        TournamentRound.RoundOf32,
        TournamentRound.Sweet16,
        TournamentRound.Elite8,
        TournamentRound.FinalFour,
        TournamentRound.NationalChampionship
    };

    private static readonly Dictionary<TournamentRound, int> _defaultPoints = new()
    {
        { TournamentRound.FirstFour,           1 },
        { TournamentRound.RoundOf64,           1 },
        { TournamentRound.RoundOf32,           2 },
        { TournamentRound.Sweet16,             4 },
        { TournamentRound.Elite8,              8 },
        { TournamentRound.FinalFour,          16 },
        { TournamentRound.NationalChampionship, 32 }
    };

    protected override async Task OnInitializedAsync()
    {
        _seasons = await SeasonService.GetSeasonsAsync();
        await LoadPools();
    }

    private async Task LoadPools()
    {
        _isLoading = true;
        _pools = await PoolService.GetPoolsAsync();
        _isLoading = false;
    }

    private void EditPool(HoopsPool pool)
    {
        if (string.IsNullOrEmpty(pool.Id))
        {
            pool.LockDate = DateTime.UtcNow.AddDays(7);
            var current = _seasons.FirstOrDefault(s => s.IsCurrent);
            if (current != null)
            {
                pool.SeasonId = current.Id;
                pool.Season = int.TryParse(current.Id, out var y) ? y : DateTime.UtcNow.Year;
            }
            else
            {
                pool.Season = DateTime.UtcNow.Year;
                pool.SeasonId = pool.Season.ToString();
            }
            pool.PointsPerRound = new Dictionary<TournamentRound, int>(_defaultPoints);
        }
        else
        {
            // Ensure all 7 rounds are present in case pool was saved with partial data
            pool.PointsPerRound ??= new Dictionary<TournamentRound, int>(_defaultPoints);
            foreach (var r in _basketballRounds)
            {
                if (!pool.PointsPerRound.ContainsKey(r))
                    pool.PointsPerRound[r] = _defaultPoints[r];
            }
        }

        _editingPool = pool;
        _lockDateString = DateTimeHelper.ToCentral(pool.LockDate).ToString("yyyy-MM-ddTHH:mm");
        _showModal = true;
    }

    private void OnSeasonChanged(string newSeasonId)
    {
        if (_editingPool == null) return;
        _editingPool.SeasonId = newSeasonId;
        var season = _seasons.FirstOrDefault(s => s.Id == newSeasonId);
        if (season != null && int.TryParse(season.Id, out var year))
            _editingPool.Season = year;
    }

    private int GetPointsForRound(TournamentRound round)
        => _editingPool?.PointsPerRound?.TryGetValue(round, out var v) == true ? v : _defaultPoints[round];

    private void SetPointsForRound(TournamentRound round, string? value)
    {
        if (_editingPool?.PointsPerRound == null) return;
        _editingPool.PointsPerRound[round] = int.TryParse(value, out var n) ? Math.Max(0, n) : 0;
    }

    private static string RoundDisplayName(TournamentRound round) => round switch
    {
        TournamentRound.FirstFour           => "First Four (Play-In)",
        TournamentRound.RoundOf64           => "Round of 64",
        TournamentRound.RoundOf32           => "Round of 32",
        TournamentRound.Sweet16             => "Sweet 16",
        TournamentRound.Elite8              => "Elite 8",
        TournamentRound.FinalFour           => "Final Four",
        TournamentRound.NationalChampionship => "National Championship",
        _ => round.ToString()
    };

    private void CloseModal()
    {
        _showModal = false;
        _editingPool = null;
    }

    private async Task SavePool()
    {
        if (_editingPool == null) return;

        if (DateTime.TryParse(_lockDateString, out var parsedLocal))
            _editingPool.LockDate = DateTimeHelper.FromCentral(parsedLocal);
        else
            return;

        HoopsPool? result = string.IsNullOrEmpty(_editingPool.Id)
            ? await PoolService.CreatePoolAsync(_editingPool)
            : await PoolService.UpdatePoolAsync(_editingPool);

        if (result != null)
        {
            CloseModal();
            await LoadPools();
        }
    }

    private async Task DeletePool(HoopsPool pool)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to DELETE '{pool.Name}'? This cannot be undone."))
            return;

        _isLoading = true;
        var success = await PoolService.DeletePoolAsync(pool.Id);
        if (success)
            await LoadPools();
        else
        {
            await JS.InvokeVoidAsync("alert", "Failed to delete pool.");
            _isLoading = false;
        }
    }

    private async Task ToggleConclusion(HoopsPool pool)
    {
        _isLoading = true;
        var updated = await PoolService.ToggleConclusionAsync(pool.Id);
        if (updated != null)
            await LoadPools();
        else
            _isLoading = false;
    }
}
