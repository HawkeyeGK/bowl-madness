@page "/admin/hoops/entry"
@page "/admin/hoops/entry/{EntryId}"
@using BowlPoolManager.Core.Domain
@using BowlPoolManager.Core
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Json
@using System.Text.Json
@using BowlPoolManager.Client.Components

@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject BowlPoolManager.Client.Services.ISeasonService SeasonService

<PageTitle>@(string.IsNullOrEmpty(EntryId) ? "New" : "Edit") Hoops Entry – Admin</PageTitle>

<div class="container-fluid mt-3 px-4 pb-5">
    <div class="d-flex justify-content-between align-items-end mb-3">
        <h1 class="h3 fw-bold mb-0">
            <i class="bi bi-pencil-square text-primary"></i>
            @(string.IsNullOrEmpty(EntryId) ? "New" : "Edit") Hoops Entry
        </h1>
        <a href="/admin/hoops/entries" class="btn btn-outline-secondary">Back to List</a>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading…</span></div>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show">
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        @* Entry Details *@
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-primary text-white">Entry Details</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Bracket Name</label>
                        <input type="text" class="form-control" @bind="entry.PlayerName" placeholder="e.g. John's Bracket" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold">Pool</label>
                        @if (string.IsNullOrEmpty(EntryId))
                        {
                            <select class="form-select" @bind="entry.PoolId" @bind:after="OnPoolChanged">
                                <option value="">-- Select Pool --</option>
                                @foreach (var p in pools.Where(p => !p.IsArchived))
                                {
                                    <option value="@p.Id">@p.Name</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input type="text" class="form-control"
                                   value="@(pools.FirstOrDefault(p => p.Id == entry.PoolId)?.Name ?? "Unknown")"
                                   disabled />
                        }
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold">Owner (User)</label>
                        <select class="form-select" @bind="entry.UserId">
                            <option value="">-- Unassigned --</option>
                            @foreach (var u in users)
                            {
                                <option value="@u.Id">@u.Email</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        @* Bracket Picker *@
        @if (!string.IsNullOrEmpty(entry.PoolId))
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white fw-bold">
                    Picks (@(entry.Picks?.Count ?? 0) / @poolGames.Count made)
                </div>
                <div class="card-body">
                    <BracketPickerComponent
                        Games="@poolGames"
                        Picks="@(entry.Picks ?? new())"
                        IsLocked="@false"
                        PicksChanged="@OnPicksChanged" />
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-info">Select a pool above to see bracket games.</div>
        }

        @* Actions *@
        <div class="d-flex gap-2 mb-4">
            @if (!string.IsNullOrEmpty(EntryId))
            {
                <button type="button" class="btn btn-danger" @onclick="DeleteEntry" disabled="@isSaving">
                    <i class="bi bi-trash"></i> Delete
                </button>
            }
            <button type="button" class="btn btn-success btn-lg px-5 ms-auto" @onclick="HandleSave" disabled="@isSaving">
                @if (isSaving) { <span class="spinner-border spinner-border-sm me-2"></span><span>Saving…</span> }
                else { <i class="bi bi-save"></i><span> Save Entry</span> }
            </button>
        </div>

        @* Audit Log *@
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-secondary text-white small py-1">
                <i class="bi bi-clock-history me-1"></i> Audit Log
            </div>
            <div class="card-body bg-light p-2" style="max-height:250px;overflow-y:auto;font-family:monospace;font-size:0.85em;">
                @if (entry.AuditLog != null && entry.AuditLog.Any())
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var log in entry.AuditLog.AsEnumerable().Reverse())
                        {
                            <li class="mb-1 border-bottom pb-1">@log</li>
                        }
                    </ul>
                }
                else
                {
                    <div class="text-muted fst-italic p-2">No audit history.</div>
                }
            </div>
        </div>
    }

    @if (showToast)
    {
        <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index:1050">
            <div class="toast show align-items-center text-white bg-success border-0 shadow" role="alert">
                <div class="d-flex">
                    <div class="toast-body fs-6"><i class="bi bi-check-circle-fill me-2"></i>@toastMessage</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => showToast = false"></button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string? EntryId { get; set; }
    [SupplyParameterFromQuery] public string? SeasonId { get; set; }

    private List<HoopsPool> pools = new();
    private List<HoopsGame> poolGames = new();
    private List<UserProfile> users = new();
    private BracketEntry entry = new BracketEntry();
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading = true;
    private bool isSaving = false;
    private bool showToast = false;
    private string toastMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;

            string targetSeasonId = SeasonId ?? "";
            if (string.IsNullOrEmpty(targetSeasonId))
            {
                var currentSeason = await SeasonService.GetCurrentSeasonAsync();
                targetSeasonId = currentSeason?.Id ?? "";
            }

            var poolsTask = Http.GetFromJsonAsync<List<HoopsPool>>("api/GetHoopsPools");
            var usersTask = Http.GetFromJsonAsync<List<UserProfile>>("api/GetUsers");

            await Task.WhenAll(poolsTask, usersTask);
            pools = await poolsTask ?? new();
            users = await usersTask ?? new();

            if (!string.IsNullOrEmpty(EntryId))
            {
                var existing = await Http.GetFromJsonAsync<BracketEntry>(
                    $"api/GetHoopsEntry?id={EntryId}&seasonId={targetSeasonId}");
                if (existing != null)
                {
                    entry = existing;
                    entry.Picks ??= new();
                    if (!string.IsNullOrEmpty(entry.PoolId))
                        await LoadPoolGames(entry.PoolId);
                }
                else
                {
                    errorMessage = "Entry not found.";
                }
            }
            else
            {
                entry.SeasonId = targetSeasonId;
                var activePools = pools.Where(p => !p.IsArchived).ToList();
                if (activePools.Count == 1)
                {
                    entry.PoolId = activePools[0].Id;
                    await LoadPoolGames(entry.PoolId);
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnPoolChanged()
    {
        if (!string.IsNullOrEmpty(entry.PoolId))
            await LoadPoolGames(entry.PoolId);
        else
            poolGames = new();
    }

    private async Task LoadPoolGames(string poolId)
    {
        try
        {
            poolGames = await Http.GetFromJsonAsync<List<HoopsGame>>(
                $"api/GetHoopsGames?poolId={poolId}") ?? new();
        }
        catch
        {
            poolGames = new();
        }
    }

    private void OnPicksChanged(Dictionary<string, string> updatedPicks)
    {
        entry.Picks = updatedPicks;
        StateHasChanged();
    }

    private async Task HandleSave()
    {
        if (string.IsNullOrEmpty(entry.PoolId))
        {
            errorMessage = "Please select a pool.";
            return;
        }

        if (string.IsNullOrWhiteSpace(entry.PlayerName))
        {
            errorMessage = "Bracket Name is required.";
            return;
        }

        successMessage = null; errorMessage = null; isSaving = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/CreateHoopsEntry", entry);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<BracketEntry>();
                if (saved != null) entry = saved;
                toastMessage = "Changes saved!";
                showToast = true;
                if (string.IsNullOrEmpty(EntryId))
                {
                    successMessage = $"Entry '{entry.PlayerName}' created!";
                    entry = new BracketEntry { SeasonId = entry.SeasonId };
                    poolGames = new();
                }
                _ = Task.Delay(3000).ContinueWith(_ => { showToast = false; InvokeAsync(StateHasChanged); });
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                errorMessage = $"Save failed: {err}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteEntry()
    {
        if (string.IsNullOrEmpty(EntryId)) return;
        bool confirmed = await JS.InvokeAsync<bool>("confirm",
            $"Delete the entry '{entry.PlayerName}'? This cannot be undone.");
        if (!confirmed) return;

        isSaving = true;
        try
        {
            string sid = !string.IsNullOrEmpty(entry.SeasonId) ? entry.SeasonId : (SeasonId ?? "");
            var response = await Http.DeleteAsync($"api/DeleteHoopsEntry/{EntryId}?seasonId={sid}");
            if (response.IsSuccessStatusCode)
                Nav.NavigateTo("/admin/hoops/entries");
            else
                errorMessage = "Error deleting entry.";
        }
        catch (Exception ex) { errorMessage = $"Error: {ex.Message}"; }
        finally { isSaving = false; }
    }
}
