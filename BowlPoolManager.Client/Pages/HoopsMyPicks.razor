@page "/hoops/mypicks"
@using BowlPoolManager.Core.Domain
@using BowlPoolManager.Core
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Json
@using BowlPoolManager.Client.Components

@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject BowlPoolManager.Client.Services.AppState AppState
@inject BowlPoolManager.Client.Services.ISeasonService SeasonService
@inject IJSRuntime JS

<PageTitle>My Picks – Hoops Madness</PageTitle>

<div class="container-fluid mt-3 px-4 pb-5 position-relative">
    <div class="d-flex justify-content-between align-items-end mb-3">
        <h1 class="h3 fw-bold mb-0">
            <i class="bi bi-clipboard-check-fill text-primary"></i> My Picks
        </h1>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading…</span></div>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mb-4 shadow-sm"><i class="bi bi-exclamation-triangle-fill me-2"></i> @errorMessage</div>
        }

        @* ── DASHBOARD ── *@
        @if (viewMode == ViewMode.Dashboard)
        {
            <div class="mb-5">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h4 text-secondary mb-0">Current Season (@currentSeasonDisplay)</h2>
                    <button class="btn btn-primary" @onclick="CreateEntry">
                        <i class="bi bi-plus-lg"></i> New Entry
                    </button>
                </div>

                @if (!currentEntries.Any())
                {
                    <div class="card shadow-sm border-0 bg-light mb-5">
                        <div class="card-body p-4 text-center">
                            <i class="bi bi-dribbble display-4 text-primary mb-3"></i>
                            <h4 class="card-title fw-bold">Fill Out Your Bracket!</h4>
                            <p class="text-muted mb-4">You don't have any brackets yet. Enter an invite code to join a pool.</p>
                            <div class="mx-auto" style="max-width: 400px;">
                                <EditForm Model="@joinModel" OnValidSubmit="StartNewEntry">
                                    <div class="input-group input-group-lg mb-3">
                                        <InputText @bind-Value="joinModel.InviteCode" class="form-control" placeholder="Enter Invite Code" />
                                        <button class="btn btn-primary" type="submit">Join Pool</button>
                                    </div>
                                </EditForm>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var entry in currentEntries)
                        {
                            var pool = hoopsPools.FirstOrDefault(p => p.Id == entry.PoolId);
                            int pickCount = entry.Picks?.Count ?? 0;
                            <div class="col-md-6 col-lg-4">
                                <div class="card h-100 shadow-sm border-0">
                                    <div class="card-header bg-white border-bottom-0 pb-0">
                                        <span class="badge bg-light text-secondary border">@(pool?.Name ?? "Unknown Pool")</span>
                                    </div>
                                    <div class="card-body pt-2">
                                        <h4 class="card-title fw-bold text-primary mb-3 text-truncate" title="@entry.PlayerName">
                                            @entry.PlayerName
                                        </h4>
                                        <div class="row text-center mb-3 g-0 border rounded bg-light py-2">
                                            <div class="col border-end">
                                                <small class="text-muted d-block">Picks Made</small>
                                                <span class="fw-bold fs-5">@pickCount</span>
                                            </div>
                                            <div class="col">
                                                <small class="text-muted d-block">of</small>
                                                <span class="fw-bold fs-5">@(poolGamesCount.TryGetValue(entry.PoolId, out var cnt) ? cnt : 67)</span>
                                            </div>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-outline-primary flex-grow-1" @onclick="() => EditEntry(entry)">
                                                <i class="bi bi-pencil-square"></i> View/Edit
                                            </button>
                                            @if (!string.IsNullOrEmpty(entry.Id))
                                            {
                                                <a href="hoops/print-bracket/@entry.Id" target="_blank" class="btn btn-outline-secondary" title="Print Bracket">
                                                    <i class="bi bi-printer-fill"></i>
                                                </a>
                                            }
                                            <button class="btn btn-outline-danger" @onclick="() => DeleteEntry(entry)" title="Delete">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            @if (pastEntries.Any())
            {
                <div class="mb-4 pt-4 border-top">
                    <h3 class="h5 text-secondary mb-3"><i class="bi bi-clock-history me-2"></i>Past Seasons</h3>
                    <div class="row g-3">
                        @foreach (var entry in pastEntries.OrderByDescending(e => e.SeasonId))
                        {
                            var pool = hoopsPools.FirstOrDefault(p => p.Id == entry.PoolId);
                            <div class="col-md-6 col-lg-4">
                                <div class="card h-100 shadow-sm border-0 bg-light">
                                    <div class="card-body">
                                        <h5 class="card-title text-dark mb-1">@(pool?.Name ?? "Unknown Pool")</h5>
                                        <p class="card-text small mt-2">Bracket: <strong>@entry.PlayerName</strong></p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }

        @* ── JOIN ── *@
        @if (viewMode == ViewMode.Join)
        {
            <div class="card shadow-sm mx-auto mt-5" style="max-width: 500px;">
                <div class="card-body p-5 text-center">
                    <button class="btn btn-sm btn-close position-absolute top-0 end-0 m-3" @onclick="BackToDashboard"></button>
                    <i class="bi bi-ticket-perforated display-1 text-secondary mb-3"></i>
                    <h3 class="mb-3">Join a Pool</h3>
                    <p class="text-muted mb-4">Enter your invite code to get started.</p>
                    <EditForm Model="@joinModel" OnValidSubmit="StartNewEntry">
                        <div class="mb-3">
                            <InputText @bind-Value="joinModel.InviteCode" class="form-control form-control-lg text-center" placeholder="e.g. HOOPS2025" />
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg w-100">Continue</button>
                    </EditForm>
                </div>
            </div>
        }

        @* ── EDITOR ── *@
        @if (viewMode == ViewMode.Editor)
        {
            var entryPool = hoopsPools.FirstOrDefault(p => p.Id == activeEntry.PoolId);
            bool isLocked = entryPool != null && DateTime.UtcNow > entryPool.LockDate;

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="d-flex align-items-center">
                    <button class="btn btn-outline-secondary me-3" @onclick="BackToDashboard">
                        <i class="bi bi-arrow-left"></i> Back
                    </button>
                    @if (!string.IsNullOrEmpty(activeEntry.Id))
                    {
                        <a href="hoops/print-bracket/@activeEntry.Id" target="_blank" class="btn btn-outline-secondary me-3" title="Print Bracket">
                            <i class="bi bi-printer-fill"></i> Print Bracket
                        </a>
                    }
                    <div>
                        <h2 class="fw-bold mb-0">
                            @(string.IsNullOrEmpty(activeEntry.Id) ? "New Entry" : "Edit Entry")
                        </h2>
                        @if (entryPool != null)
                        {
                            <div class="small text-muted">@entryPool.Name</div>
                        }
                        @if (isLocked)
                        {
                            <span class="badge" style="background-color:#ffc107;color:#000;"><i class="bi bi-lock-fill"></i> Locked</span>
                        }
                        else if (entryPool != null)
                        {
                            <span class="text-muted small">Deadline: @entryPool.LockDate.ToLocalTime().ToString("g")</span>
                        }
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill"></i> @errorMessage</div>
            }

            @* Bracket Name *@
            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <label class="form-label fw-bold">Bracket Name</label>
                    <input type="text" class="form-control" @bind="activeEntry.PlayerName"
                           disabled="@isLocked" placeholder="Give this bracket a unique name" />
                </div>
            </div>

            @* Bracket Picker *@
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white fw-bold">
                    Make Your Picks
                </div>
                <div class="card-body">
                    <BracketPickerComponent
                        Games="@activePoolGames"
                        Picks="@(activeEntry.Picks ?? new())"
                        IsLocked="@isLocked"
                        PicksChanged="@OnPicksChanged" />
                </div>
            </div>

            @* Save *@
            @if (!isLocked)
            {
                <div class="d-grid gap-2 mb-5">
                    <button class="btn btn-success btn-lg" @onclick="SavePicks" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span><span>Saving…</span>
                        }
                        else
                        {
                            <i class="bi bi-save-fill"></i><span> Save Bracket</span>
                        }
                    </button>
                </div>
            }

            @* Audit Log *@
            <div class="card mb-4 shadow-sm mt-3">
                <div class="card-header bg-secondary text-white small py-1">
                    <i class="bi bi-clock-history me-1"></i> Change History
                </div>
                <div class="card-body bg-light p-2" style="max-height:200px;overflow-y:auto;font-family:monospace;font-size:0.85em;">
                    @if (activeEntry.AuditLog != null && activeEntry.AuditLog.Any())
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var log in activeEntry.AuditLog.AsEnumerable().Reverse())
                            {
                                <li class="mb-1 border-bottom pb-1">@log</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-muted fst-italic p-2">No changes recorded.</div>
                    }
                </div>
            </div>
        }
    }

    @* Toast *@
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index:1050">
        <div class="toast @(showToast ? "show" : "hide") align-items-center @(toastType == "warning" ? "bg-warning text-dark" : toastType == "success" ? "bg-success text-white" : "bg-danger text-white") border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body fs-6">
                    <i class="@(toastType == "success" ? "bi bi-check-circle-fill" : toastType == "warning" ? "bi bi-exclamation-circle-fill" : "bi bi-exclamation-triangle-fill") me-2"></i>@toastMessage
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => showToast = false"></button>
            </div>
        </div>
    </div>
</div>

@code {
    private enum ViewMode { Dashboard, Join, Editor }
    private ViewMode viewMode = ViewMode.Dashboard;

    private class JoinModel { public string InviteCode { get; set; } = ""; }
    private JoinModel joinModel = new();

    private bool isLoading = true;
    private bool isSaving = false;
    private string errorMessage = "";

    private bool showToast;
    private string toastType = "success"; // "success", "warning", "danger"
    private string toastMessage = "";

    private List<HoopsPool> hoopsPools = new();
    private List<BracketEntry> currentEntries = new();
    private List<BracketEntry> pastEntries = new();
    private BracketEntry activeEntry = new() { Picks = new() };
    private List<HoopsGame> activePoolGames = new();

    // GameId count per pool for display
    private Dictionary<string, int> poolGamesCount = new();

    private string currentSeasonId = "";
    private string currentSeasonDisplay = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;

            var seasons = await SeasonService.GetSeasonsAsync();
            var activeSeason = seasons.FirstOrDefault(s => s.IsCurrent) ?? seasons.OrderByDescending(s => s.Id).FirstOrDefault();
            if (activeSeason != null)
            {
                currentSeasonId = activeSeason.Id;
                currentSeasonDisplay = activeSeason.SeasonId;
            }

            var poolsTask = Http.GetFromJsonAsync<List<HoopsPool>>("api/GetHoopsPools");
            var entriesTask = Http.GetFromJsonAsync<List<BracketEntry>>("api/GetMyHoopsEntries");

            await Task.WhenAll(poolsTask, entriesTask);

            hoopsPools = await poolsTask ?? new();
            var allEntries = await entriesTask ?? new();

            // Classify by pool membership — more robust than SeasonId comparison, which
            // can fail if the pool's SeasonId doesn't match the Season document's GUID Id.
            var activePoolIds = hoopsPools.Where(p => !p.IsArchived).Select(p => p.Id).ToHashSet();
            currentEntries = allEntries.Where(e => activePoolIds.Contains(e.PoolId)).ToList();
            pastEntries    = allEntries.Where(e => !activePoolIds.Contains(e.PoolId)).ToList();

            // Pre-fetch game counts for dashboard display
            foreach (var pool in hoopsPools)
                poolGamesCount[pool.Id] = pool.GameIds.Count;
        }
        catch (Exception ex)
        {
            errorMessage = "Error loading data: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void CreateEntry()
    {
        errorMessage = "";
        joinModel.InviteCode = "";
        viewMode = ViewMode.Join;
    }

    private async Task StartNewEntry()
    {
        if (string.IsNullOrWhiteSpace(joinModel.InviteCode))
        {
            TriggerToast("Please enter an invite code.", "danger");
            return;
        }

        string code = joinModel.InviteCode.Trim();

        var targetPool = hoopsPools.FirstOrDefault(p =>
            string.Equals(p.InviteCode, code, StringComparison.OrdinalIgnoreCase) &&
            !p.IsArchived);

        if (targetPool == null)
        {
            TriggerToast("Invalid invite code.", "danger");
            return;
        }

        if (DateTime.UtcNow > targetPool.LockDate)
        {
            TriggerToast("This pool is locked for new entries.", "danger");
            return;
        }

        activeEntry = new BracketEntry { Picks = new(), PoolId = targetPool.Id };
        activePoolGames = await LoadPoolGames(targetPool.Id);
        viewMode = ViewMode.Editor;
    }

    private async Task EditEntry(BracketEntry entry)
    {
        activeEntry = System.Text.Json.JsonSerializer.Deserialize<BracketEntry>(
            System.Text.Json.JsonSerializer.Serialize(entry)) ?? new BracketEntry();

        activeEntry.Picks ??= new();
        errorMessage = "";

        var pool = hoopsPools.FirstOrDefault(p => p.Id == activeEntry.PoolId);
        if (pool != null)
            activePoolGames = await LoadPoolGames(pool.Id);

        viewMode = ViewMode.Editor;
    }

    private async Task<List<HoopsGame>> LoadPoolGames(string poolId)
    {
        try
        {
            return await Http.GetFromJsonAsync<List<HoopsGame>>($"api/GetHoopsGames?poolId={poolId}") ?? new();
        }
        catch
        {
            return new();
        }
    }

    private void BackToDashboard()
    {
        viewMode = ViewMode.Dashboard;
        errorMessage = "";
        activePoolGames = new();
    }

    private void OnPicksChanged(Dictionary<string, string> updatedPicks)
    {
        activeEntry.Picks = updatedPicks;
        StateHasChanged();
    }

    private async Task DeleteEntry(BracketEntry entry)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm",
            $"Delete the bracket '{entry.PlayerName}'? This cannot be undone.");
        if (!confirmed) return;

        isSaving = true;
        try
        {
            var response = await Http.DeleteAsync($"api/DeleteHoopsEntry/{entry.Id}?seasonId={entry.SeasonId}");
            if (response.IsSuccessStatusCode)
            {
                currentEntries.Remove(entry);
                pastEntries.Remove(entry);
                TriggerToast("Bracket deleted.", "success");
                AppState.NotifyDataChanged();
                StateHasChanged();
            }
            else
            {
                var msg = await response.Content.ReadAsStringAsync();
                TriggerToast($"Delete failed: {msg}", "danger");
            }
        }
        catch (Exception ex)
        {
            TriggerToast($"Error: {ex.Message}", "danger");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SavePicks()
    {
        activeEntry.Picks ??= new();

        if (string.IsNullOrWhiteSpace(activeEntry.PlayerName))
        {
            TriggerToast("Please enter a bracket name.", "danger");
            return;
        }

        isSaving = true;
        errorMessage = "";

        try
        {
            string url = "api/CreateHoopsEntry?assignToMe=true";
            if (string.IsNullOrEmpty(activeEntry.Id))
            {
                activeEntry.Id = "";
                if (!string.IsNullOrEmpty(joinModel.InviteCode))
                    url += $"&inviteCode={joinModel.InviteCode}";
            }

            var response = await Http.PostAsJsonAsync(url, activeEntry);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<BracketEntry>();
                if (saved != null)
                {
                    var list = hoopsPools.Any(p => !p.IsArchived && p.Id == saved.PoolId)
                        ? currentEntries : pastEntries;
                    var idx = list.FindIndex(e => e.Id == saved.Id);
                    if (idx >= 0) list[idx] = saved; else list.Add(saved);

                    int picksMade = saved.Picks?.Count ?? 0;
                    int picksNeeded = activePoolGames.Count;
                    if (picksMade < picksNeeded)
                        TriggerToast($"Bracket saved, but you still have {picksNeeded - picksMade} pick{(picksNeeded - picksMade == 1 ? "" : "s")} remaining.", "warning");
                    else
                        TriggerToast("Bracket complete and saved!", "success");
                    viewMode = ViewMode.Dashboard;
                    AppState.NotifyDataChanged();
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                errorMessage = await response.Content.ReadAsStringAsync();
                TriggerToast("Name already taken in this pool.", "danger");
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                errorMessage = $"Save failed: {err}";
                TriggerToast($"Save failed: {err}", "danger");
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void TriggerToast(string message, string type)
    {
        toastMessage = message;
        toastType = type;
        showToast = true;
        _ = Task.Delay(4000).ContinueWith(_ =>
        {
            showToast = false;
            InvokeAsync(StateHasChanged);
        });
    }
}
