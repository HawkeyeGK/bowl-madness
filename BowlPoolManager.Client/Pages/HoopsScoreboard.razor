@page "/hoops/scoreboard"
@using BowlPoolManager.Core.Domain
@inject IHoopsPoolService PoolService
@inject IHoopsGameService GameService
@inject HttpClient Http

<PageTitle>Hoops Scoreboard</PageTitle>

<div class="container-fluid mt-3 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-0"><i class="bi bi-display text-primary me-2"></i>Scoreboard</h1>
            <div class="text-muted small">Tournament results by round</div>
        </div>
        @if (_isLoading)
        {
            <div class="spinner-border text-primary spinner-border-sm" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        }
    </div>

    @if (_isLoading && _games == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Loading games...</p>
        </div>
    }
    else if (_games == null || !_games.Any())
    {
        <div class="alert alert-info">No games available yet.</div>
    }
    else
    {
        @* Today's Games section *@
        @if (_todaysGames.Any())
        {
            var hasLiveToday = _todaysGames.Any(g => g.Status == GameStatus.InProgress);

            <div class="mb-5">
                <div class="d-flex align-items-center gap-2 mb-3 border-bottom pb-2">
                    <h5 class="fw-bold mb-0 text-warning"><i class="bi bi-calendar-day me-1"></i>Today's Games</h5>
                    @if (hasLiveToday)
                    {
                        <span class="badge bg-danger" style="font-size: 0.7em;">
                            <span class="spinner-grow spinner-grow-sm me-1" role="status" aria-hidden="true" style="width: 5px; height: 5px;"></span>
                            LIVE
                        </span>
                    }
                </div>
                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3 mb-3">
                    @foreach (var game in _todaysGames)
                    {
                        <div class="col" @key="@($"today-{game.Id}")">
                            <div class="card h-100 shadow-sm @GetCardClass(game)">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-end align-items-start mb-2">
                                        <span class="badge @GetStatusBadgeClass(game)">@GetStatusLabel(game)</span>
                                    </div>

                                    @* Home Team *@
                                    <div class="d-flex justify-content-between align-items-center mb-1 @(IsWinner(game, true) ? "fw-bold" : "")">
                                        <div class="d-flex align-items-center gap-2">
                                            @if (!string.IsNullOrEmpty(game.HomeTeamInfo?.PrimaryLogoUrl))
                                            {
                                                <img src="@game.HomeTeamInfo.PrimaryLogoUrl" height="24" width="24" style="object-fit: contain;" alt="" />
                                            }
                                            @if (game.TeamHomeSeed.HasValue)
                                            {
                                                <span class="badge bg-secondary" style="font-size: 0.7em; min-width: 22px;">@game.TeamHomeSeed</span>
                                            }
                                            <span class="small @(IsEliminated(game, true) ? "text-decoration-line-through text-muted" : "")">
                                                @GetDisplayTeamName(game, true)
                                            </span>
                                            @{ var homePctT = GetPickPct(game, true); }
                                            @if (homePctT.HasValue)
                                            {
                                                <span class="text-muted small">(@homePctT%)</span>
                                            }
                                        </div>
                                        @if (game.TeamHomeScore.HasValue)
                                        {
                                            <span class="fw-bold @(IsWinner(game, true) ? "text-success" : "")">@game.TeamHomeScore</span>
                                        }
                                    </div>

                                    @* Away Team *@
                                    <div class="d-flex justify-content-between align-items-center @(IsWinner(game, false) ? "fw-bold" : "")">
                                        <div class="d-flex align-items-center gap-2">
                                            @if (!string.IsNullOrEmpty(game.AwayTeamInfo?.PrimaryLogoUrl))
                                            {
                                                <img src="@game.AwayTeamInfo.PrimaryLogoUrl" height="24" width="24" style="object-fit: contain;" alt="" />
                                            }
                                            @if (game.TeamAwaySeed.HasValue)
                                            {
                                                <span class="badge bg-secondary" style="font-size: 0.7em; min-width: 22px;">@game.TeamAwaySeed</span>
                                            }
                                            <span class="small @(IsEliminated(game, false) ? "text-decoration-line-through text-muted" : "")">
                                                @GetDisplayTeamName(game, false)
                                            </span>
                                            @{ var awayPctT = GetPickPct(game, false); }
                                            @if (awayPctT.HasValue)
                                            {
                                                <span class="text-muted small">(@awayPctT%)</span>
                                            }
                                        </div>
                                        @if (game.TeamAwayScore.HasValue)
                                        {
                                            <span class="fw-bold @(IsWinner(game, false) ? "text-success" : "")">@game.TeamAwayScore</span>
                                        }
                                    </div>

                                    @if (game.StartTime.HasValue || !string.IsNullOrEmpty(game.Television))
                                    {
                                        <div class="text-muted small text-end mt-1">
                                            @if (game.StartTime.HasValue)
                                            {
                                                <span>@game.StartTime.Value.AddHours(-5).ToString("MMM d, h:mm tt") CT</span>
                                            }
                                            @if (game.StartTime.HasValue && !string.IsNullOrEmpty(game.Television))
                                            {
                                                <span class="mx-1">·</span>
                                            }
                                            @if (!string.IsNullOrEmpty(game.Television))
                                            {
                                                <span>@game.Television</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @foreach (var round in _roundOrder)
        {
            var roundGames = _games.Where(g => g.Round == round).ToList();
            if (!roundGames.Any()) continue;

            var hasLive = roundGames.Any(g => g.Status == GameStatus.InProgress);

            <div class="mb-5">
                <div class="d-flex align-items-center gap-2 mb-3 border-bottom pb-2">
                    <h5 class="fw-bold mb-0 text-primary">@GetRoundLabel(round)</h5>
                    @if (hasLive)
                    {
                        <span class="badge bg-danger" style="font-size: 0.7em;">
                            <span class="spinner-grow spinner-grow-sm me-1" role="status" aria-hidden="true" style="width: 5px; height: 5px;"></span>
                            LIVE
                        </span>
                    }
                </div>

                @* Group by region within round *@
                @foreach (var region in roundGames.Select(g => g.Region ?? "").Distinct().OrderBy(r => r))
                {
                    var regionGames = roundGames.Where(g => (g.Region ?? "") == region)
                        .OrderBy(g => g.Status == GameStatus.InProgress ? 0 : g.Status == GameStatus.Final ? 1 : 2)
                        .ThenBy(g => g.Id).ToList();

                    @if (!string.IsNullOrEmpty(region) && roundGames.Select(g => g.Region ?? "").Distinct().Count() > 1)
                    {
                        <h6 class="text-muted fw-semibold mb-2 ms-1">@region</h6>
                    }

                    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3 mb-3">
                        @foreach (var game in regionGames)
                        {
                            <div class="col" @key="game.Id">
                                <div class="card h-100 shadow-sm @GetCardClass(game)">
                                    <div class="card-body p-3">
                                        <div class="d-flex justify-content-end align-items-start mb-2">
                                            <span class="badge @GetStatusBadgeClass(game)">@GetStatusLabel(game)</span>
                                        </div>

                                        @* Home Team *@
                                        <div class="d-flex justify-content-between align-items-center mb-1 @(IsWinner(game, true) ? "fw-bold" : "")">
                                            <div class="d-flex align-items-center gap-2">
                                                @if (!string.IsNullOrEmpty(game.HomeTeamInfo?.PrimaryLogoUrl))
                                                {
                                                    <img src="@game.HomeTeamInfo.PrimaryLogoUrl" height="24" width="24" style="object-fit: contain;" alt="" />
                                                }
                                                @if (game.TeamHomeSeed.HasValue)
                                                {
                                                    <span class="badge bg-secondary" style="font-size: 0.7em; min-width: 22px;">@game.TeamHomeSeed</span>
                                                }
                                                <span class="small @(IsEliminated(game, true) ? "text-decoration-line-through text-muted" : "")">
                                                    @GetDisplayTeamName(game, true)
                                                </span>
                                                @{ var homePct = GetPickPct(game, true); }
                                                @if (homePct.HasValue)
                                                {
                                                    <span class="text-muted small">(@homePct%)</span>
                                                }
                                            </div>
                                            @if (game.TeamHomeScore.HasValue)
                                            {
                                                <span class="fw-bold @(IsWinner(game, true) ? "text-success" : "")">@game.TeamHomeScore</span>
                                            }
                                        </div>

                                        @* Away Team *@
                                        <div class="d-flex justify-content-between align-items-center @(IsWinner(game, false) ? "fw-bold" : "")">
                                            <div class="d-flex align-items-center gap-2">
                                                @if (!string.IsNullOrEmpty(game.AwayTeamInfo?.PrimaryLogoUrl))
                                                {
                                                    <img src="@game.AwayTeamInfo.PrimaryLogoUrl" height="24" width="24" style="object-fit: contain;" alt="" />
                                                }
                                                @if (game.TeamAwaySeed.HasValue)
                                                {
                                                    <span class="badge bg-secondary" style="font-size: 0.7em; min-width: 22px;">@game.TeamAwaySeed</span>
                                                }
                                                <span class="small @(IsEliminated(game, false) ? "text-decoration-line-through text-muted" : "")">
                                                    @GetDisplayTeamName(game, false)
                                                </span>
                                                @{ var awayPct = GetPickPct(game, false); }
                                                @if (awayPct.HasValue)
                                                {
                                                    <span class="text-muted small">(@awayPct%)</span>
                                                }
                                            </div>
                                            @if (game.TeamAwayScore.HasValue)
                                            {
                                                <span class="fw-bold @(IsWinner(game, false) ? "text-success" : "")">@game.TeamAwayScore</span>
                                            }
                                        </div>

                                        @if (game.StartTime.HasValue || !string.IsNullOrEmpty(game.Television))
                                        {
                                            <div class="text-muted small text-end mt-1">
                                                @if (game.StartTime.HasValue)
                                                {
                                                    // Tournament games display in CDT (UTC-5)
                                                    <span>@game.StartTime.Value.AddHours(-5).ToString("MMM d, h:mm tt") CT</span>
                                                }
                                                @if (game.StartTime.HasValue && !string.IsNullOrEmpty(game.Television))
                                                {
                                                    <span class="mx-1">·</span>
                                                }
                                                @if (!string.IsNullOrEmpty(game.Television))
                                                {
                                                    <span>@game.Television</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private List<HoopsGame>? _games;
    private bool _isLoading = true;
    private Dictionary<string, Dictionary<string, int>> _pickCountsByGame = new();

    private List<HoopsGame> _todaysGames =>
        _games == null ? new() :
        _games
            .Where(g => g.StartTime.HasValue && g.StartTime.Value.AddHours(-5).Date == DateTime.UtcNow.AddHours(-5).Date)
            .OrderBy(g => g.StartTime)
            .ToList();

    private static readonly TournamentRound[] _roundOrder =
    [
        TournamentRound.FirstFour,
        TournamentRound.RoundOf64,
        TournamentRound.RoundOf32,
        TournamentRound.Sweet16,
        TournamentRound.Elite8,
        TournamentRound.FinalFour,
        TournamentRound.NationalChampionship
    ];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _isLoading = true;
            var pools = await PoolService.GetPoolsAsync();
            var activePool = pools.FirstOrDefault(p => !p.IsConcluded) ?? pools.FirstOrDefault();
            if (activePool != null)
            {
                var gamesTask = GameService.GetGamesAsync(activePool.Id);
                var entriesTask = Http.GetFromJsonAsync<List<BracketEntry>>($"api/GetHoopsEntries?poolId={activePool.Id}");
                await Task.WhenAll(gamesTask, entriesTask);
                _games = await gamesTask;
                var entries = await entriesTask ?? new();
                ComputePickCounts(entries);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading hoops scoreboard: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ComputePickCounts(List<BracketEntry> entries)
    {
        _pickCountsByGame = new();
        foreach (var entry in entries)
        {
            if (entry.Picks == null) continue;
            foreach (var (gameId, pick) in entry.Picks)
            {
                if (string.IsNullOrEmpty(pick)) continue;
                if (!_pickCountsByGame.TryGetValue(gameId, out var gameCounts))
                {
                    gameCounts = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
                    _pickCountsByGame[gameId] = gameCounts;
                }
                gameCounts.TryGetValue(pick, out var existing);
                gameCounts[pick] = existing + 1;
            }
        }
    }

    private int? GetPickPct(HoopsGame game, bool isHome)
    {
        var teamName = isHome ? game.TeamHome : game.TeamAway;
        if (string.IsNullOrEmpty(teamName) || IsPlaceholder(teamName)) return null;
        if (!_pickCountsByGame.TryGetValue(game.Id, out var counts)) return null;
        int total = counts.Values.Sum();
        if (total == 0) return null;
        counts.TryGetValue(teamName, out var teamCount);
        return (int)Math.Round(teamCount * 100.0 / total);
    }

    private static string GetRoundLabel(TournamentRound round) => round switch
    {
        TournamentRound.FirstFour => "First Four",
        TournamentRound.RoundOf64 => "Round of 64",
        TournamentRound.RoundOf32 => "Round of 32",
        TournamentRound.Sweet16 => "Sweet 16",
        TournamentRound.Elite8 => "Elite 8",
        TournamentRound.FinalFour => "Final Four",
        TournamentRound.NationalChampionship => "National Championship",
        _ => round.ToString()
    };

    private static string GetStatusLabel(HoopsGame game) => game.Status switch
    {
        GameStatus.Final => "Final",
        GameStatus.InProgress => game.GameDetail ?? "In Progress",
        _ => game.StartTime.HasValue ? "Scheduled" : "Pending"
    };

    private static string GetStatusBadgeClass(HoopsGame game) => game.Status switch
    {
        GameStatus.Final => "bg-success",
        GameStatus.InProgress => "bg-danger",
        _ => "bg-secondary opacity-75"
    };

    private static string GetCardClass(HoopsGame game) => game.Status switch
    {
        GameStatus.InProgress => "border-warning border-2",
        GameStatus.Final => "opacity-90",
        _ => ""
    };

    private static bool IsWinner(HoopsGame game, bool isHome)
    {
        if (game.Status != GameStatus.Final) return false;
        var winner = game.WinningTeamName;
        if (string.IsNullOrEmpty(winner)) return false;
        var team = isHome ? game.TeamHome : game.TeamAway;
        return string.Equals(winner, team, StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsEliminated(HoopsGame game, bool isHome)
    {
        if (game.Status != GameStatus.Final) return false;
        var winner = game.WinningTeamName;
        if (string.IsNullOrEmpty(winner)) return false;
        var team = isHome ? game.TeamHome : game.TeamAway;
        return !string.Equals(winner, team, StringComparison.OrdinalIgnoreCase);
    }

    private string GetDisplayTeamName(HoopsGame game, bool isHome)
    {
        string current = isHome ? game.TeamHome : game.TeamAway;
        if (!IsPlaceholder(current)) return current;

        if (_games == null) return "TBD";

        var feeders = _games
            .Where(g => string.Equals(g.NextGameId, game.Id, StringComparison.OrdinalIgnoreCase))
            .OrderBy(g => (int)g.Round).ThenBy(g => g.Id)
            .ToList();

        if (!feeders.Any()) return "TBD";

        HoopsGame? targetFeeder = null;

        if (feeders.Count > 1)
        {
            targetFeeder = isHome ? feeders[0] : feeders[1];
        }
        else
        {
            string otherSlot = isHome ? game.TeamAway : game.TeamHome;
            bool otherIsPlaceholder = IsPlaceholder(otherSlot);
            var feederWinner = feeders[0].Status == GameStatus.Final ? feeders[0].WinningTeamName : null;

            if (!otherIsPlaceholder)
            {
                if (feederWinner != null && string.Equals(feederWinner, otherSlot, StringComparison.OrdinalIgnoreCase))
                    targetFeeder = null;
                else
                    targetFeeder = feeders[0];
            }
            else
            {
                if (isHome) targetFeeder = feeders[0];
            }
        }

        if (targetFeeder == null) return "TBD";

        return targetFeeder.Status == GameStatus.Final && !string.IsNullOrEmpty(targetFeeder.WinningTeamName)
            ? targetFeeder.WinningTeamName
            : "TBD";
    }

    private static bool IsPlaceholder(string name)
    {
        if (string.IsNullOrEmpty(name)) return true;
        if (name.Equals("TBD", StringComparison.OrdinalIgnoreCase)) return true;
        if (name.StartsWith("Winner of", StringComparison.OrdinalIgnoreCase)) return true;
        return false;
    }
}
