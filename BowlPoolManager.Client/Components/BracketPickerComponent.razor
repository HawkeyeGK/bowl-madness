@using BowlPoolManager.Core.Domain
@using BowlPoolManager.Client.Helpers

@if (!Games.Any())
{
    <div class="alert alert-info">No bracket games found for this pool.</div>
}
else
{
    @* ── Region Tabs ── *@
    <ul class="nav nav-tabs mb-3 flex-nowrap overflow-auto bracket-nav-tabs">
        @{
            int firstFourTotal = GamesForFirstFour().Count;
        }
        @if (firstFourTotal > 0)
        {
            int firstFourMade = PicksForFirstFour();
            bool firstFourComplete = firstFourMade == firstFourTotal;

            <li class="nav-item flex-shrink-0">
                <button class="nav-link @(activeTab == "First Four" ? "active fw-bold" : "") px-2 px-md-3"
                        @onclick="@(() => activeTab = "First Four")">
                    First Four
                    <span class="badge ms-1 @(firstFourComplete ? "bg-success" : "bg-secondary")" style="font-size:0.7em;">
                        @firstFourMade/@firstFourTotal
                    </span>
                </button>
            </li>
        }

        @foreach (var region in AvailableRegions)
        {
            int made = PicksForRegion(region);
            int total = GamesForRegion(region).Count;
            bool complete = made == total;
            <li class="nav-item flex-shrink-0">
                <button class="nav-link @(activeTab == region ? "active fw-bold" : "") px-2 px-md-3"
                        @onclick="() => activeTab = region">
                    @region
                    <span class="badge ms-1 @(complete ? "bg-success" : "bg-secondary")" style="font-size:0.7em;">
                        @made/@total
                    </span>
                </button>
            </li>
        }

        @{
            int ffMade = PicksForFinalFour();
            int ffTotal = GamesForFinalFour().Count;
            bool ffComplete = ffMade == ffTotal && ffTotal > 0;
        }
        <li class="nav-item flex-shrink-0">
            <button class="nav-link @(activeTab == "Final Four" ? "active fw-bold" : "") px-2 px-md-3"
                    @onclick="@(() => activeTab = "Final Four")">
                Final Four
                @if (ffTotal > 0)
                {
                    <span class="badge ms-1 @(ffComplete ? "bg-success" : "bg-secondary")" style="font-size:0.7em;">
                        @ffMade/@ffTotal
                    </span>
                }
            </button>
        </li>
    </ul>

    @* ── Active Tab Content ── *@
    @if (activeTab == "First Four")
    {
        <FirstFourBracket Games="GamesForFirstFour()"
                          Picks="Picks"
                          IsLocked="IsLocked"
                          ResolveMatchupTeams="ResolveMatchupTeams"
                          GetSeedDisplay="GetSeedDisplay"
                          GetGameLabel="GetGameLabel"
                          OnPick="HandlePick" />
    }
    else if (activeTab == "Final Four")
    {
        <FinalFourBracket Games="GamesForFinalFour()"
                          AllGames="Games"
                          Picks="Picks"
                          IsLocked="IsLocked"
                          ResolveMatchupTeams="ResolveMatchupTeams"
                          GetSeedDisplay="GetSeedDisplay"
                          GetGameLabel="GetGameLabel"
                          OnPick="HandlePick" />
    }
    else
    {
        <RegionBracket Games="GamesForRegion(activeTab)"
                       Picks="Picks"
                       IsLocked="IsLocked"
                       ResolveMatchupTeams="ResolveMatchupTeams"
                       GetSeedDisplay="GetSeedDisplay"
                       GetGameLabel="GetGameLabel"
                       OnPick="HandlePick" />
    }

    @* ── Progress summary ── *@
    <div class="mt-3 pt-3 border-top">
        @{
            int totalPicks = Picks.Count;
            int totalGames = Games.Count;
        }
        <div class="d-flex justify-content-between align-items-center">
            <small class="text-muted">
                <i class="bi bi-clipboard-check me-1"></i>
                Total picks: <strong>@totalPicks / @totalGames</strong>
            </small>
            @if (totalPicks == totalGames && totalGames > 0)
            {
                <span class="badge" style="background-color:#198754;color:#fff;"><i class="bi bi-check-all me-1"></i>Bracket Complete!</span>
            }
            else
            {
                <span class="badge" style="background-color:#ffc107;color:#000;">@(totalGames - totalPicks) picks remaining</span>
            }
        </div>
    </div>
}

<style>
    .bracket-nav-tabs .nav-link {
        color: #495057;
        border: 1px solid #ced4da;
        border-radius: 4px 4px 0 0;
        margin-right: 2px;
    }

    .bracket-nav-tabs .nav-link:hover:not(.active) {
        background-color: #f8f9fa;
        color: #212529;
        border-color: #adb5bd;
    }

    .bracket-nav-tabs .nav-link.active {
        color: #212529;
    }
</style>

@code {
    [Parameter, EditorRequired] public List<HoopsGame> Games { get; set; } = new();
    [Parameter, EditorRequired] public Dictionary<string, string> Picks { get; set; } = new();
    [Parameter] public bool IsLocked { get; set; }
    [Parameter] public EventCallback<Dictionary<string, string>> PicksChanged { get; set; }

    private string activeTab = "";
    private Dictionary<string, int?> _seedCache = new(StringComparer.OrdinalIgnoreCase);

    private List<string> AvailableRegions => Games
        .Where(g => g.Round > TournamentRound.FirstFour && g.Round < TournamentRound.FinalFour && !string.IsNullOrEmpty(g.Region))
        .Select(g => g.Region!)
        .Distinct()
        .OrderBy(r => r)
        .ToList();

    protected override void OnParametersSet()
    {
        _seedCache = new Dictionary<string, int?>(StringComparer.OrdinalIgnoreCase);
        foreach (var g in Games)
        {
            if (!string.IsNullOrEmpty(g.TeamHome) && g.TeamHomeSeed.HasValue)
                _seedCache.TryAdd(g.TeamHome, g.TeamHomeSeed);
            if (!string.IsNullOrEmpty(g.TeamAway) && g.TeamAwaySeed.HasValue)
                _seedCache.TryAdd(g.TeamAway, g.TeamAwaySeed);
        }

        if (string.IsNullOrEmpty(activeTab) || (!AvailableRegions.Contains(activeTab) && activeTab != "Final Four" && activeTab != "First Four"))
        {
            if (GamesForFirstFour().Any())
                activeTab = "First Four";
            else
                activeTab = AvailableRegions.FirstOrDefault() ?? "Final Four";
        }
    }

    private List<HoopsGame> GamesForFirstFour() =>
        Games.Where(g => g.Round == TournamentRound.FirstFour).ToList();

    private int PicksForFirstFour() =>
        GamesForFirstFour().Count(g => Picks.ContainsKey(g.Id) && !string.IsNullOrEmpty(Picks[g.Id]));

    private List<HoopsGame> GamesForRegion(string region) =>
        Games.Where(g => g.Region == region && g.Round > TournamentRound.FirstFour && g.Round < TournamentRound.FinalFour).ToList();

    private int PicksForRegion(string region) =>
        GamesForRegion(region).Count(g => Picks.ContainsKey(g.Id) && !string.IsNullOrEmpty(Picks[g.Id]));

    private List<HoopsGame> GamesForFinalFour() =>
        Games.Where(g => g.Round >= TournamentRound.FinalFour).ToList();

    private int PicksForFinalFour() =>
        GamesForFinalFour().Count(g => Picks.ContainsKey(g.Id) && !string.IsNullOrEmpty(Picks[g.Id]));

    private string GetGameLabel(HoopsGame game) => game.Round switch
    {
        TournamentRound.FirstFour => $"First Four",
        TournamentRound.RoundOf64 => !string.IsNullOrEmpty(game.SeedMatchup) ? $"{game.SeedMatchup}" : "Round of 64",
        TournamentRound.RoundOf32 => "Round of 32",
        TournamentRound.Sweet16 => "Sweet 16",
        TournamentRound.Elite8 => "Elite 8",
        TournamentRound.FinalFour => "National Semifinal",
        TournamentRound.NationalChampionship => "National Championship",
        _ => game.Round.ToString()
    };

    private (string Home, string Away) ResolveMatchupTeams(HoopsGame game)
    {
        var feeders = Games.Where(g => g.NextGameId == game.Id).OrderBy(g => g.Id).ToList();
        int feederIdx = 0;

        string home = game.TeamHome ?? "";
        if (string.IsNullOrWhiteSpace(home) || home == "TBD")
        {
            if (feederIdx < feeders.Count)
            {
                var f = feeders[feederIdx++];
                Picks.TryGetValue(f.Id, out home!);
                if (string.IsNullOrEmpty(home)) home = GetFeederLabel(f);
            }
            else home = "";
        }

        string away = game.TeamAway ?? "";
        if (string.IsNullOrWhiteSpace(away) || away == "TBD")
        {
            if (feederIdx < feeders.Count)
            {
                var f = feeders[feederIdx++];
                Picks.TryGetValue(f.Id, out away!);
                if (string.IsNullOrEmpty(away)) away = GetFeederLabel(f);
            }
            else away = "";
        }

        return (home, away);
    }

    private string GetFeederLabel(HoopsGame feeder)
    {
        if (!string.IsNullOrEmpty(feeder.SeedMatchup))
            return $"Win of {feeder.SeedMatchup}";
        if (!string.IsNullOrEmpty(feeder.Region))
            return $"{feeder.Region} winner";

        // For Final Four games (Championship feeders), build "Region1/Region2 winner"
        var e8Feeders = Games.Where(g => g.NextGameId == feeder.Id).ToList();
        var regions = e8Feeders
            .Select(g => g.Region ?? "")
            .Where(r => r.Length > 0)
            .OrderBy(r => r)
            .ToList();
        if (regions.Count > 0)
            return $"{string.Join("/", regions)} winner";

        return "TBD";
    }

    private int? GetSeedDisplay(HoopsGame game, bool homeSlot)
    {
        if (homeSlot && game.TeamHomeSeed.HasValue) return game.TeamHomeSeed;
        if (!homeSlot && game.TeamAwaySeed.HasValue) return game.TeamAwaySeed;

        var (home, away) = ResolveMatchupTeams(game);
        var teamName = homeSlot ? home : away;
        if (!string.IsNullOrEmpty(teamName) && teamName != "TBD" && _seedCache.TryGetValue(teamName, out var seed))
            return seed;

        return null;
    }

    private async Task HandlePick((HoopsGame Game, string Pick) args)
    {
        if (IsLocked || string.IsNullOrEmpty(args.Pick) || args.Pick == "TBD") return;

        var picks = new Dictionary<string, string>(Picks);

        picks.TryGetValue(args.Game.Id, out var oldPick);
        picks[args.Game.Id] = args.Pick;

        if (!string.IsNullOrEmpty(oldPick) &&
            !string.Equals(oldPick, args.Pick, StringComparison.OrdinalIgnoreCase))
        {
            BracketLayoutHelper.CascadeClear(args.Game.Id, oldPick, picks, Games);
        }

        await PicksChanged.InvokeAsync(picks);
    }
}
