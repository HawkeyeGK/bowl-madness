@using BowlPoolManager.Core.Domain
@using BowlPoolManager.Client.Helpers

<div class="bracket-region-container shadow-inner">
    @foreach(var (round, roundGames) in Columns)
    {
        <div class="bracket-column round-@(round)">
            <div class="bracket-column-header">@RoundLabel(round)</div>
            <div class="bracket-games">
                @foreach(var game in roundGames)
                {
                    var (home, away) = ResolveMatchupTeams?.Invoke(game) ?? ("", "");
                    var currentPick = Picks.TryGetValue(game.Id, out var p) ? p : "";

                    bool homeAvailable = !string.IsNullOrEmpty(home) && home != "TBD";
                    bool awayAvailable = !string.IsNullOrEmpty(away) && away != "TBD";
                    int? homeSeed = GetSeedDisplay?.Invoke(game, true);
                    int? awaySeed = GetSeedDisplay?.Invoke(game, false);
                    var pickCounts = AllPickCounts.TryGetValue(game.Id, out var pc) ? pc : new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);

                    <BracketMatchup
                        Game="game"
                        GameLabel="@GetGameLabel?.Invoke(game)"
                        CurrentPick="@currentPick"
                        IsLocked="IsLocked"
                        HomeName="@home"
                        HomeSeed="homeSeed"
                        HomeIsAvailable="homeAvailable"
                        AwayName="@away"
                        AwaySeed="awaySeed"
                        AwayIsAvailable="awayAvailable"
                        PickCounts="pickCounts"
                        GhostPick="@(GhostPicks.TryGetValue(game.Id, out var gp) ? gp : "")"
                        OnPick="HandlePick" />
                }
            </div>
        </div>
        
        @if (round != TournamentRound.Elite8)
        {
            <div class="bracket-connector">
                <!-- css-based SVGs connecting the columns can go here later if needed -->
            </div>
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public List<HoopsGame> Games { get; set; } = new();
    [Parameter, EditorRequired] public Dictionary<string, string> Picks { get; set; } = new();
    [Parameter] public bool IsLocked { get; set; }
    
    [Parameter] public Func<HoopsGame, (string Home, string Away)>? ResolveMatchupTeams { get; set; }
    [Parameter] public Func<HoopsGame, bool, int?>? GetSeedDisplay { get; set; }
    [Parameter] public Func<HoopsGame, string>? GetGameLabel { get; set; }
    [Parameter] public Dictionary<string, string> GhostPicks { get; set; } = new();
    [Parameter] public Dictionary<string, Dictionary<string, int>> AllPickCounts { get; set; } = new();

    [Parameter] public EventCallback<(HoopsGame Game, string Pick)> OnPick { get; set; }

    private List<(TournamentRound Round, List<HoopsGame> Games)> Columns = new();

    protected override void OnParametersSet()
    {
        var r64Games = Games.Where(g => g.Round == TournamentRound.RoundOf64)
                            .OrderBy(g => BracketLayoutHelper.GetSeedMatchupOrder(g.SeedMatchup))
                            .ToList();

        var r32Games = BracketLayoutHelper.OrderByFeeder(Games.Where(g => g.Round == TournamentRound.RoundOf32), r64Games);
        var s16Games = BracketLayoutHelper.OrderByFeeder(Games.Where(g => g.Round == TournamentRound.Sweet16), r32Games);
        var e8Games  = BracketLayoutHelper.OrderByFeeder(Games.Where(g => g.Round == TournamentRound.Elite8), s16Games);

        Columns = new()
        {
            (TournamentRound.RoundOf64, r64Games),
            (TournamentRound.RoundOf32, r32Games),
            (TournamentRound.Sweet16, s16Games),
            (TournamentRound.Elite8, e8Games)
        };
    }

    private static string RoundLabel(TournamentRound round) => round switch
    {
        TournamentRound.RoundOf64 => "Round of 64",
        TournamentRound.RoundOf32 => "Round of 32",
        TournamentRound.Sweet16   => "Sweet 16",
        TournamentRound.Elite8    => "Elite 8",
        _                         => round.ToString()
    };

    private async Task HandlePick((HoopsGame Game, string Pick) args)
    {
        await OnPick.InvokeAsync(args);
    }
}
