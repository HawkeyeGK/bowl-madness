@using BowlPoolManager.Core.Domain

@{
    int _total = PickCounts.Values.Sum();
    bool _hasWinner = !string.IsNullOrEmpty(CurrentPick);
    int _correctCount = _hasWinner && PickCounts.TryGetValue(CurrentPick, out var _cc) ? _cc : 0;
    int _correctPct = _total > 0 && _hasWinner ? (int)Math.Round(_correctCount * 100.0 / _total) : 0;
    int _wrongPct = 100 - _correctPct;
    int _homePct = _total > 0 && HomeIsAvailable ? (int)Math.Round((PickCounts.TryGetValue(HomeName, out var _hc) ? _hc : 0) * 100.0 / _total) : 0;
    int _awayPct = _total > 0 && AwayIsAvailable ? (int)Math.Round((PickCounts.TryGetValue(AwayName, out var _ac) ? _ac : 0) * 100.0 / _total) : 0;
    string _barTooltip = _total > 0 ? $"{HomeName}: {_homePct}% · {AwayName}: {_awayPct}%" : "";
}
<div class="bracket-matchup card shadow-sm border @(string.IsNullOrEmpty(CurrentPick) ? "border-light" : "border-primary border-opacity-50")">
    <div class="card-body p-1">
        <div class="d-flex flex-column gap-1">
            <button class="btn btn-sm @(CurrentPick == HomeName && HomeIsAvailable ? "btn-primary" : "btn-outline-secondary") text-start pick-btn d-flex align-items-center"
                    disabled="@(IsLocked || !HomeIsAvailable)"
                    @onclick="() => OnPickClick(HomeName)">
                @if (HomeSeed.HasValue) { <span class="badge bg-secondary me-1" style="font-size: 0.65rem;">@HomeSeed</span> }
                <span class="team-name text-truncate flex-grow-1">@(HomeIsAvailable ? HomeName : "TBD")</span>
                @if (!string.IsNullOrEmpty(GhostPick) && string.Equals(GhostPick, HomeName, StringComparison.OrdinalIgnoreCase) && HomeIsAvailable)
                {
                    <i class="bi bi-star-fill ms-1 ghost-indicator" title="This entry's pick" aria-label="This entry's pick"></i>
                }
            </button>
            <div style="padding:4px 0;cursor:default;"
                 title="@_barTooltip">
                <div style="height:5px;display:flex;overflow:hidden;border-radius:2px;background-color:#dee2e6;">
                    @if (_total > 0 && _hasWinner)
                    {
                        <div style="width:@_correctPct%;background-color:#198754;"></div>
                        <div style="width:@_wrongPct%;background-color:#dc3545;"></div>
                    }
                </div>
            </div>
            <button class="btn btn-sm @(CurrentPick == AwayName && AwayIsAvailable ? "btn-primary" : "btn-outline-secondary") text-start pick-btn d-flex align-items-center"
                    disabled="@(IsLocked || !AwayIsAvailable)"
                    @onclick="() => OnPickClick(AwayName)">
                @if (AwaySeed.HasValue) { <span class="badge bg-secondary me-1" style="font-size: 0.65rem;">@AwaySeed</span> }
                <span class="team-name text-truncate flex-grow-1">@(AwayIsAvailable ? AwayName : "TBD")</span>
                @if (!string.IsNullOrEmpty(GhostPick) && string.Equals(GhostPick, AwayName, StringComparison.OrdinalIgnoreCase) && AwayIsAvailable)
                {
                    <i class="bi bi-star-fill ms-1 ghost-indicator" title="This entry's pick" aria-label="This entry's pick"></i>
                }
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public HoopsGame Game { get; set; } = default!;
    [Parameter] public string GameLabel { get; set; } = "";
    [Parameter] public string CurrentPick { get; set; } = "";
    [Parameter] public bool IsLocked { get; set; }

    [Parameter] public string HomeName { get; set; } = "";
    [Parameter] public int? HomeSeed { get; set; }
    [Parameter] public bool HomeIsAvailable { get; set; }

    [Parameter] public string AwayName { get; set; } = "";
    [Parameter] public int? AwaySeed { get; set; }
    [Parameter] public bool AwayIsAvailable { get; set; }

    /// <summary>
    /// Pick counts for this game keyed by team name. Used to render the correct-pick consensus bar.
    /// </summary>
    [Parameter] public Dictionary<string, int> PickCounts { get; set; } = new(StringComparer.OrdinalIgnoreCase);

    [Parameter] public EventCallback<(HoopsGame Game, string Pick)> OnPick { get; set; }

    /// <summary>
    /// Optional: team name picked by the "ghosted" entry. Shows a star indicator
    /// on that team's button without affecting the current-pick highlight.
    /// </summary>
    [Parameter] public string GhostPick { get; set; } = "";

    private async Task OnPickClick(string teamName)
    {
        if (IsLocked || string.IsNullOrEmpty(teamName) || teamName == "TBD") return;
        await OnPick.InvokeAsync((Game, teamName));
    }
}
