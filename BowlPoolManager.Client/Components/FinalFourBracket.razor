@using BowlPoolManager.Core.Domain

<div class="final-four-container d-flex justify-content-center align-items-center gap-4 py-4 overflow-auto px-4 shadow-inner">
    <!-- Left Semifinal -->
    <div class="ff-column">
        <h6 class="text-center text-secondary text-uppercase fw-bold mb-3">@SF1Label</h6>
        @if (SemiFinal1 != null) {
            var (home, away) = ResolveMatchupTeams?.Invoke(SemiFinal1) ?? ("", "");
            var currentPick = Picks.TryGetValue(SemiFinal1.Id, out var p) ? p : "";

            bool homeAvailable = !string.IsNullOrEmpty(home) && home != "TBD";
            bool awayAvailable = !string.IsNullOrEmpty(away) && away != "TBD";
            int? homeSeed = GetSeedDisplay?.Invoke(SemiFinal1, true);
            int? awaySeed = GetSeedDisplay?.Invoke(SemiFinal1, false);
            var pickCounts1 = AllPickCounts.TryGetValue(SemiFinal1.Id, out var pc1) ? pc1 : new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);

            <BracketMatchup
                Game="SemiFinal1"
                GameLabel="@GetGameLabel?.Invoke(SemiFinal1)"
                CurrentPick="@currentPick"
                IsLocked="IsLocked"
                HomeName="@home"
                HomeSeed="homeSeed"
                HomeIsAvailable="homeAvailable"
                AwayName="@away"
                AwaySeed="awaySeed"
                AwayIsAvailable="awayAvailable"
                PickCounts="pickCounts1"
                GhostPick="@(GhostPicks.TryGetValue(SemiFinal1.Id, out var g1) ? g1 : "")"
                OnPick="HandlePick" />
        }
    </div>

    <!-- Championship -->
    <div class="ff-column champ-column">
        <h4 class="text-center text-warning fw-bold mb-3"><i class="bi bi-trophy-fill me-2"></i>Championship</h4>
        @if (Championship != null) {
            var (home, away) = ResolveMatchupTeams?.Invoke(Championship) ?? ("", "");
            var currentPick = Picks.TryGetValue(Championship.Id, out var p) ? p : "";

            bool homeAvailable = !string.IsNullOrEmpty(home) && home != "TBD";
            bool awayAvailable = !string.IsNullOrEmpty(away) && away != "TBD";
            int? homeSeed = GetSeedDisplay?.Invoke(Championship, true);
            int? awaySeed = GetSeedDisplay?.Invoke(Championship, false);
            var pickCountsC = AllPickCounts.TryGetValue(Championship.Id, out var pcC) ? pcC : new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);

            <BracketMatchup
                Game="Championship"
                GameLabel="@GetGameLabel?.Invoke(Championship)"
                CurrentPick="@currentPick"
                IsLocked="IsLocked"
                HomeName="@home"
                HomeSeed="homeSeed"
                HomeIsAvailable="homeAvailable"
                AwayName="@away"
                AwaySeed="awaySeed"
                AwayIsAvailable="awayAvailable"
                PickCounts="pickCountsC"
                GhostPick="@(GhostPicks.TryGetValue(Championship.Id, out var gc) ? gc : "")"
                OnPick="HandlePick" />
        }
    </div>

    <!-- Right Semifinal -->
    <div class="ff-column">
        <h6 class="text-center text-secondary text-uppercase fw-bold mb-3">@SF2Label</h6>
        @if (SemiFinal2 != null) {
            var (home, away) = ResolveMatchupTeams?.Invoke(SemiFinal2) ?? ("", "");
            var currentPick = Picks.TryGetValue(SemiFinal2.Id, out var p) ? p : "";

            bool homeAvailable = !string.IsNullOrEmpty(home) && home != "TBD";
            bool awayAvailable = !string.IsNullOrEmpty(away) && away != "TBD";
            int? homeSeed = GetSeedDisplay?.Invoke(SemiFinal2, true);
            int? awaySeed = GetSeedDisplay?.Invoke(SemiFinal2, false);
            var pickCounts2 = AllPickCounts.TryGetValue(SemiFinal2.Id, out var pc2) ? pc2 : new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);

            <BracketMatchup
                Game="SemiFinal2"
                GameLabel="@GetGameLabel?.Invoke(SemiFinal2)"
                CurrentPick="@currentPick"
                IsLocked="IsLocked"
                HomeName="@home"
                HomeSeed="homeSeed"
                HomeIsAvailable="homeAvailable"
                AwayName="@away"
                AwaySeed="awaySeed"
                AwayIsAvailable="awayAvailable"
                PickCounts="pickCounts2"
                GhostPick="@(GhostPicks.TryGetValue(SemiFinal2.Id, out var g2) ? g2 : "")"
                OnPick="HandlePick" />
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public List<HoopsGame> Games { get; set; } = new();
    /// <summary>Full game list (all 67) — used to resolve E8 feeders for region labels.</summary>
    [Parameter] public List<HoopsGame> AllGames { get; set; } = new();
    [Parameter, EditorRequired] public Dictionary<string, string> Picks { get; set; } = new();
    [Parameter] public bool IsLocked { get; set; }

    [Parameter] public Func<HoopsGame, (string Home, string Away)>? ResolveMatchupTeams { get; set; }
    [Parameter] public Func<HoopsGame, bool, int?>? GetSeedDisplay { get; set; }
    [Parameter] public Func<HoopsGame, string>? GetGameLabel { get; set; }
    [Parameter] public Dictionary<string, string> GhostPicks { get; set; } = new();
    [Parameter] public Dictionary<string, Dictionary<string, int>> AllPickCounts { get; set; } = new();

    [Parameter] public EventCallback<(HoopsGame Game, string Pick)> OnPick { get; set; }

    private HoopsGame? SemiFinal1;
    private HoopsGame? SemiFinal2;
    private HoopsGame? Championship;
    private string SF1Label = "National Semifinal";
    private string SF2Label = "National Semifinal";

    protected override void OnParametersSet()
    {
        // Sort semifinals by the alphabetically-first E8 feeder region for stable left-right placement.
        var ffGames = Games
            .Where(g => g.Round == TournamentRound.FinalFour)
            .OrderBy(g => GetStableSortKey(g))
            .ToList();

        SemiFinal1 = ffGames.ElementAtOrDefault(0);
        SemiFinal2 = ffGames.ElementAtOrDefault(1);
        Championship = Games.FirstOrDefault(g => g.Round == TournamentRound.NationalChampionship);

        SF1Label = BuildRegionLabel(SemiFinal1);
        SF2Label = BuildRegionLabel(SemiFinal2);
    }

    /// <summary>
    /// Returns the alphabetically-first E8 feeder region for <paramref name="ffGame"/>,
    /// falling back to the game ID so the sort is always stable.
    /// </summary>
    private string GetStableSortKey(HoopsGame ffGame)
    {
        var firstFeederRegion = AllGames
            .Where(g => g.Round == TournamentRound.Elite8 && g.NextGameId == ffGame.Id)
            .Select(g => g.Region ?? "")
            .Where(r => r.Length > 0)
            .OrderBy(r => r)
            .FirstOrDefault();

        return firstFeederRegion ?? ffGame.Id;
    }

    /// <summary>Returns a "Region1 / Region2" label derived from the E8 feeders of <paramref name="ffGame"/>.</summary>
    private string BuildRegionLabel(HoopsGame? ffGame)
    {
        if (ffGame == null) return "National Semifinal";

        var regions = AllGames
            .Where(g => g.Round == TournamentRound.Elite8 && g.NextGameId == ffGame.Id)
            .Select(g => g.Region ?? "")
            .Where(r => r.Length > 0)
            .OrderBy(r => r)
            .ToList();

        return regions.Count > 0
            ? string.Join(" / ", regions)
            : "National Semifinal";
    }

    private async Task HandlePick((HoopsGame Game, string Pick) args)
    {
        await OnPick.InvokeAsync(args);
    }
}
